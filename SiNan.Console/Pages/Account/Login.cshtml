@page
@model SiNan.Console.Pages.Account.LoginModel
@{
    ViewData["Title"] = L["Auth.Login"];
}

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-brand">
            <img class="auth-logo" src="~/images/logo.svg" alt="SiNan Logo" />
            <div>
                <p class="eyebrow">@L["Auth.Login"]</p>
                <h1 class="auth-title">@L["Auth.Login"]</h1>
                <p class="muted">@L["Auth.LoginSubtitle"]</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-warning">@Model.ErrorMessage</div>
        }

        <div class="auth-panel">
            <div class="panel-title">@L["Auth.LoginPanel"]</div>
            <form method="post" class="config-form">
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                <div class="form-grid auth-grid">
                    <div>
                        <label class="form-label">@L["Auth.UserName"]</label>
                        <input class="form-control" name="userName" value="@Model.UserName" autocomplete="username" />
                    </div>
                    <div>
                        <label class="form-label">@L["Auth.Password"]</label>
                        <input class="form-control" name="password" type="password" autocomplete="current-password" />
                    </div>
                </div>
                <button class="btn btn-primary w-100" type="submit">@L["Auth.SignIn"]</button>
            </form>
        </div>
    </div>
</div>
