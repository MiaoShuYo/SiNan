@{
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @L["Brand.Name"]</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SiNan.Console.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark app-nav">
            <div class="container">
                <a class="navbar-brand brand" asp-area="" asp-page="/Index">@L["Brand.Name"]</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">@L["Nav.Overview"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Services/Index">@L["Nav.Services"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Configs/Index">@L["Nav.Configs"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Audit/Index">@L["Nav.Audit"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Privacy">@L["Nav.Privacy"]</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-lg-center">
                        <li class="nav-item">
                            <span class="nav-link small text-uppercase">@L["Nav.Language"]</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/culture/set?culture=zh-CN&returnUrl=@Uri.EscapeDataString(returnUrl)">@L["Nav.LanguageZh"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/culture/set?culture=en-US&returnUrl=@Uri.EscapeDataString(returnUrl)">@L["Nav.LanguageEn"]</a>
                        </li>
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link small">@L["Auth.UserLabel"] @User.Identity?.Name</span>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-page="/Account/Logout" class="d-inline">
                                    <button class="btn btn-link nav-link" type="submit">@L["Auth.Logout"]</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Account/Login">@L["Auth.Login"]</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container app-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            &copy; @DateTime.Now.Year - @L["Brand.Name"]
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
