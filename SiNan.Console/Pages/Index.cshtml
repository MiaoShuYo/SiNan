@page
@model IndexModel
@{
    ViewData["Title"] = L["Title.Overview"];
}

<section class="hero">
    <div>
        <p class="eyebrow">@L["Home.Eyebrow"]</p>
        <h1>@L["Home.HeroTitle"]</h1>
        <p class="muted">@L["Home.HeroSubtitle"]</p>
        <div class="hero-actions">
            <a class="btn btn-primary" asp-page="/Services/Index">@L["Home.Actions.Services"]</a>
            <a class="btn btn-outline-light" asp-page="/Configs/Index">@L["Home.Actions.Configs"]</a>
        </div>
    </div>
    <div class="hero-card">
        <div class="hero-card-title">@L["Home.QuickEntry"]</div>
        <ul>
            <li>@L["Home.QuickItem.Services"]</li>
            <li>@L["Home.QuickItem.Configs"]</li>
            <li>@L["Home.QuickItem.Filter"]</li>
        </ul>
    </div>
</section>

<section class="grid-cards">
    <article class="panel card">
        <h3>@L["Home.Card.ServicesTitle"]</h3>
        <p>@L["Home.Card.ServicesDesc"]</p>
        <a class="link" asp-page="/Services/Index">@L["Home.Card.ServicesLink"]</a>
    </article>
    <article class="panel card">
        <h3>@L["Home.Card.ConfigsTitle"]</h3>
        <p>@L["Home.Card.ConfigsDesc"]</p>
        <a class="link" asp-page="/Configs/Index">@L["Home.Card.ConfigsLink"]</a>
    </article>
    <article class="panel card">
        <h3>@L["Home.Card.RuntimeTitle"]</h3>
        <p>@L["Home.Card.RuntimeDesc"]</p>
    </article>
</section>
