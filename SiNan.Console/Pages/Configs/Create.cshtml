@page
@model SiNan.Console.Pages.Configs.CreateModel
@{
    ViewData["Title"] = L["Title.CreateConfig"];
}

<section class="page-header">
    <div>
        <p class="eyebrow">@L["CreateConfig.Eyebrow"]</p>
        <h1>@L["CreateConfig.Title"]</h1>
        <p class="muted">@L["CreateConfig.Subtitle"]</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/Configs/Index">@L["Action.BackToConfigs"]</a>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<div class="panel">
    <div class="panel-title">@L["Panel.ConfigContent"]</div>
    <form method="post" class="config-form">
        <div class="form-grid">
            <div>
                <label class="form-label">@L["Label.Namespace"]</label>
                <input class="form-control" name="namespace" value="@Model.Namespace" placeholder="default" />
            </div>
            <div>
                <label class="form-label">@L["Label.Group"]</label>
                <input class="form-control" name="group" value="@Model.Group" placeholder="DEFAULT_GROUP" />
            </div>
            <div>
                <label class="form-label">@L["Label.Key"]</label>
                <input class="form-control" name="key" value="@Model.Key" placeholder="orders.timeout" />
            </div>
            <div>
                <label class="form-label">@L["Label.ContentType"]</label>
                <input class="form-control" name="contentType" value="@Model.ContentType" placeholder="text/plain" />
            </div>
            <div>
                <label class="form-label">@L["Label.PublishedBy"]</label>
                <input class="form-control" name="publishedBy" value="@Model.PublishedBy" placeholder="operator" />
            </div>
            <div>
                <label class="form-label">@L["Label.Token"]</label>
                <input class="form-control" name="token" value="@Model.Token" placeholder="X-SiNan-Token" />
            </div>
        </div>
        <div>
            <label class="form-label">@L["Label.Content"]</label>
            <textarea class="form-control" name="content" rows="10">@Model.Content</textarea>
        </div>
        <button class="btn btn-primary" type="submit">@L["Action.CreatePublish"]</button>
    </form>
</div>
