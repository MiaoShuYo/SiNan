@page
@model SiNan.Console.Pages.Configs.IndexModel
@{
    ViewData["Title"] = L["Title.Configs"];
}

<section class="page-header">
    <div>
        <p class="eyebrow">@L["Configs.Eyebrow"]</p>
        <h1>@L["Configs.Title"]</h1>
        <p class="muted">@L["Configs.Subtitle"]</p>
    </div>
    <div>
        <a class="btn btn-outline-primary" asp-page="/Configs/Create">@L["Action.CreateConfig"]</a>
    </div>
    <form method="get" class="filter-form">
        <div>
            <label class="form-label">@L["Label.Namespace"]</label>
            <input class="form-control" name="namespace" value="@Model.Namespace" placeholder="default" />
        </div>
        <div>
            <label class="form-label">@L["Label.Group"]</label>
            <input class="form-control" name="group" value="@Model.Group" placeholder="DEFAULT_GROUP" />
        </div>
        <button class="btn btn-primary" type="submit">@L["Action.Search"]</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<div class="panel">
    <div class="panel-title">@L["Panel.ConfigItems"]</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["Table.Key"]</th>
                    <th>@L["Label.Namespace"]</th>
                    <th>@L["Label.Group"]</th>
                    <th>@L["Table.ContentType"]</th>
                    <th>@L["Table.Version"]</th>
                    <th>@L["Table.UpdatedAt"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Configs.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-muted">@L["Empty.Configs"]</td>
                </tr>
            }
            else
            {
                foreach (var item in Model.Configs)
                {
                    <tr>
                        <td class="fw-semibold">@item.Key</td>
                        <td>@item.Namespace</td>
                        <td>@item.Group</td>
                        <td>@item.ContentType</td>
                        <td>@item.Version</td>
                        <td>@item.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Configs/Details" asp-route-namespace="@item.Namespace" asp-route-group="@item.Group" asp-route-key="@item.Key">@L["Action.Details"]</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
