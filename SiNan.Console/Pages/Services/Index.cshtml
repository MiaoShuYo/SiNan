@page
@model SiNan.Console.Pages.Services.IndexModel
@{
    ViewData["Title"] = L["Title.Services"];
}

<section class="page-header">
    <div>
        <p class="eyebrow">@L["Services.Eyebrow"]</p>
        <h1>@L["Services.Title"]</h1>
        <p class="muted">@L["Services.Subtitle"]</p>
    </div>
    <form method="get" class="filter-form">
        <div>
            <label class="form-label">@L["Label.Namespace"]</label>
            <input class="form-control" name="namespace" value="@Model.Namespace" placeholder="default" />
        </div>
        <div>
            <label class="form-label">@L["Label.Group"]</label>
            <input class="form-control" name="group" value="@Model.Group" placeholder="DEFAULT_GROUP" />
        </div>
        <button class="btn btn-primary" type="submit">@L["Action.Search"]</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<div class="panel">
    <div class="panel-title">@L["Panel.Services"]</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["Table.ServiceName"]</th>
                    <th>@L["Label.Namespace"]</th>
                    <th>@L["Label.Group"]</th>
                    <th>@L["Table.Instances"]</th>
                    <th>@L["Table.Healthy"]</th>
                    <th>@L["Table.UpdatedAt"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Services.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-muted">@L["Empty.Services"]</td>
                </tr>
            }
            else
            {
                foreach (var service in Model.Services)
                {
                    <tr>
                        <td class="fw-semibold">@service.ServiceName</td>
                        <td>@service.Namespace</td>
                        <td>@service.Group</td>
                        <td>@service.InstanceCount</td>
                        <td>@service.HealthyInstanceCount</td>
                        <td>@service.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Services/Details" asp-route-namespace="@service.Namespace" asp-route-group="@service.Group" asp-route-serviceName="@service.ServiceName">@L["Action.Instances"]</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
