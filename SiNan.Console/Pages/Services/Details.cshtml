@page
@model SiNan.Console.Pages.Services.DetailsModel
@{
    ViewData["Title"] = L["Title.ServiceInstances"];
}

<section class="page-header">
    <div>
        <p class="eyebrow">@L["ServicesDetails.Eyebrow"]</p>
        <h1>@L["ServicesDetails.Title", Model.ServiceName]</h1>
        <p class="muted">@L["ServicesDetails.Meta", Model.Namespace, Model.Group]</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/Services/Index">@L["Action.BackToServices"]</a>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<div class="panel">
    <div class="panel-title">@L["Panel.Instances"]</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["Table.InstanceId"]</th>
                    <th>@L["Table.Host"]</th>
                    <th>@L["Table.Port"]</th>
                    <th>@L["Table.Weight"]</th>
                    <th>@L["Table.Healthy"]</th>
                    <th>@L["Table.Ttl"]</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Instances.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-muted">@L["Empty.Instances"]</td>
                </tr>
            }
            else
            {
                foreach (var instance in Model.Instances)
                {
                    <tr>
                        <td class="fw-semibold">@instance.InstanceId</td>
                        <td>@instance.Host</td>
                        <td>@instance.Port</td>
                        <td>@instance.Weight</td>
                        <td>@(instance.Healthy ? L["Value.Healthy"] : L["Value.Unhealthy"])</td>
                        <td>@instance.TtlSeconds</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
