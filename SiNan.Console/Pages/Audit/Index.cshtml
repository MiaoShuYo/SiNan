@page
@model SiNan.Console.Pages.Audit.IndexModel
@{
    ViewData["Title"] = L["Title.Audit"];
}

<section class="page-header">
    <div>
        <p class="eyebrow">@L["Audit.Eyebrow"]</p>
        <h1>@L["Audit.Title"]</h1>
        <p class="muted">@L["Audit.Subtitle"]</p>
    </div>
    <form method="get" class="filter-form">
        <div>
            <label class="form-label">@L["Label.Token"]</label>
            <input class="form-control" name="token" value="@Model.Token" placeholder="X-SiNan-Token" />
        </div>
        <div>
            <label class="form-label">@L["Label.Action"]</label>
            <input class="form-control" name="action" value="@Model.Action" placeholder="config.update" />
        </div>
        <div>
            <label class="form-label">@L["Label.Resource"]</label>
            <input class="form-control" name="resource" value="@Model.Resource" placeholder="config:default" />
        </div>
        <div>
            <label class="form-label">@L["Label.Take"]</label>
            <input class="form-control" type="number" name="take" value="@Model.Take" min="1" max="500" />
        </div>
        <div>
            <label class="form-label">@L["Label.FromUtc"]</label>
            <input class="form-control" type="datetime-local" name="from" value="@Model.From" />
        </div>
        <div>
            <label class="form-label">@L["Label.ToUtc"]</label>
            <input class="form-control" type="datetime-local" name="to" value="@Model.To" />
        </div>
        <button class="btn btn-primary" type="submit">@L["Action.Search"]</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<div class="panel">
    <div class="panel-title">@L["Panel.Recent"]</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["Table.Time"]</th>
                    <th>@L["Table.Actor"]</th>
                    <th>@L["Table.Action"]</th>
                    <th>@L["Table.Resource"]</th>
                    <th>@L["Table.Trace"]</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Logs.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-muted">@L["Empty.Audit"]</td>
                </tr>
            }
            else
            {
                foreach (var log in Model.Logs)
                {
                    <tr>
                        <td>@log.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@log.Actor</td>
                        <td>@log.Action</td>
                        <td>@log.Resource</td>
                        <td>@log.TraceId</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
