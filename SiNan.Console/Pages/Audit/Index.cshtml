@page
@model SiNan.Console.Pages.Audit.IndexModel
@{
    ViewData["Title"] = "Audit";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Audit</p>
        <h1>审计日志</h1>
        <p class="muted">展示最近的操作记录（需要管理员 Token）。</p>
    </div>
    <form method="get" class="filter-form">
        <div>
            <label class="form-label">Token</label>
            <input class="form-control" name="token" value="@Model.Token" placeholder="X-SiNan-Token" />
        </div>
        <div>
            <label class="form-label">Action</label>
            <input class="form-control" name="action" value="@Model.Action" placeholder="config.update" />
        </div>
        <div>
            <label class="form-label">Resource</label>
            <input class="form-control" name="resource" value="@Model.Resource" placeholder="config:default" />
        </div>
        <div>
            <label class="form-label">Take</label>
            <input class="form-control" type="number" name="take" value="@Model.Take" min="1" max="500" />
        </div>
        <div>
            <label class="form-label">From (UTC)</label>
            <input class="form-control" type="datetime-local" name="from" value="@Model.From" />
        </div>
        <div>
            <label class="form-label">To (UTC)</label>
            <input class="form-control" type="datetime-local" name="to" value="@Model.To" />
        </div>
        <button class="btn btn-primary" type="submit">查询</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<div class="panel">
    <div class="panel-title">最近记录</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>时间</th>
                    <th>Actor</th>
                    <th>Action</th>
                    <th>Resource</th>
                    <th>Trace</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Logs.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-muted">暂无数据</td>
                </tr>
            }
            else
            {
                foreach (var log in Model.Logs)
                {
                    <tr>
                        <td>@log.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@log.Actor</td>
                        <td>@log.Action</td>
                        <td>@log.Resource</td>
                        <td>@log.TraceId</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
