{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Data": {
    "Provider": "MySql"
  },
  "ConnectionStrings": {
    "SiNan": "Server=localhost;Port=3306;Database=sinan;User Id=root;Password=change-me;"
  },
  "Registry": {
    "Health": {
      "Enabled": true,
      "CheckIntervalSeconds": 5,
      "EvictionGraceSeconds": 30
    }
  },
  "Config": {
    "HistoryCleanup": {
      "Enabled": true,
      "CheckIntervalMinutes": 10,
      "MaxVersionsPerKey": 20,
      "MaxAgeDays": 30
    }
  },
  "Auth": {
    "Enabled": false,
    "HeaderName": "X-SiNan-Token",
    "ActorHeaderName": "X-SiNan-Actor",
    "ApiKeys": [
      {
        "Key": "change-me",
        "Actor": "admin",
        "IsAdmin": true,
        "Namespaces": ["default"],
        "Groups": ["DEFAULT_GROUP"],
        "AllowedActions": [],
        "AllowedResources": []
      }
    ]
  },
  "ConsoleAuth": {
    "BootstrapAdmin": {
      "UserName": "admin",
      "Password": "ChangeMe123!"
    }
  },
  "Quota": {
    "MaxServicesPerNamespace": 0,
    "MaxInstancesPerNamespace": 0,
    "MaxConfigsPerNamespace": 0,
    "MaxConfigContentLength": 0
  }
}
