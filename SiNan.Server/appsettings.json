{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Data": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "SiNan": "Data Source=sinan.db"
  },
  "Registry": {
    "Health": {
      "Enabled": true,
      "CheckIntervalSeconds": 5,
      "EvictionGraceSeconds": 30
    }
  },
  "Config": {
    "HistoryCleanup": {
      "Enabled": true,
      "CheckIntervalMinutes": 10,
      "MaxVersionsPerKey": 20,
      "MaxAgeDays": 30
    }
  }
}
